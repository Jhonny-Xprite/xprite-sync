OPENROUTER_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# --------------------------------------------
# Search & Research Tools
# --------------------------------------------
EXA_API_KEY=

# --------------------------------------------
# Project Management & Workflows
# --------------------------------------------
GITHUB_TOKEN=
N8N_API_KEY=
N8N_WEBHOOK_URL=

# --------------------------------------------
# Epic 4 — VPS Infrastructure (AIOX Extension)
# --------------------------------------------

# SSH Connection
VPS_IP=92.112.176.118
VPS_USER=root
VPS_CONNECT_TIMEOUT=10

# Health Thresholds (%)
VPS_RAM_THRESHOLD=80
VPS_DISK_THRESHOLD=75

# Easypanel API
# Get at: https://easypanel.jhonnyxprite.com/settings/api
EASYPANEL_API_TOKEN=

# Cloudflare Tunnel & Ollama
OLLAMA_VPS_URL=https://ollama-aiox.jhonnyxprite.com
OLLAMA_VPS_TOKEN=cb0f400d-a6d8-4ec8-a350-097fe0a20b3c

